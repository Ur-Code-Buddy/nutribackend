# ==========================================
# Core Application Configuration
# ==========================================

# The base URL where the backend application is hosted (e.g., Docker environment, EC2 instance)
BASE_URL=

# The URL for the frontend application (used for CORS and redirect links)
FRONTEND_URL=

# The production URL of the backend application
PRODUCTION_URL=

# Indicates whether the application is running in production mode (true/false)
PRODUCTION=false

# The current version of the application
CURRENT_VERSION=1.0.0


# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================

# Example configurations for Aiven PostgreSQL (Commented out)
# DB_HOST= # Hostname for the Aiven database
# DB_PORT= # Port for the Aiven database
# DB_USERNAME= # Username for the Aiven database
# DB_PASSWORD= # Password for the Aiven database
# DB_NAME= # Database name for the Aiven database
# DB_SSL= # Whether SSL is required for Aiven (true/false)

# Primary NeonDB / PostgreSQL connection configurations
DB_HOST= # The hostname or endpoint of your PostgreSQL server
DB_PORT=5432 # The port your PostgreSQL server is listening on
DB_NAME= # The name of the database to connect to
DB_USERNAME= # The user role to log in as
DB_PASSWORD= # The password for the database user
DB_SSL=true # Indicates whether to use a secure SSL connection to the DB
PGCHANNELBINDING='require' # Specifies the channel binding requirement for PostgreSQL


# ==========================================
# Security & Authentication
# ==========================================

# Secret key used for signing JSON Web Tokens (JWT) for user authentication
JWT_SECRET=
# The expiration duration for JWT tokens (e.g., 1d, 1h, 30m)
JWT_EXPIRATION=1d

# Admin access password used for Super Authentication/Admin panel endpoints
ADMIN_ACCESS_PASS=
SUPER_ADMIN_ACCESS_PASS=


# ==========================================
# Third-Party Services Integration
# ==========================================

# ---- AWS S3 (Storage) ----
# AWS Access Key ID with S3 bucket permissions
AWS_ACCESS_KEY_ID=
# AWS Secret Access Key for authentication
AWS_SECRET_ACCESS_KEY=
# The AWS region where your S3 bucket is hosted (e.g., ap-south-1)
AWS_REGION=
# The name of the S3 bucket to be used for storing assets/files
AWS_BUCKET_NAME=

# ---- Brevo (Email Service) ----
# API key for Brevo (formerly Sendinblue) used to send transactional emails
BREVO_API_KEY=

# ---- SMS Verification Service ----
# The customer ID for the SMS/OTP verification provider
SMS_CUSTOMER_ID=
# The API key required to send SMS messages
SMS_API_KEY=


# ==========================================
# Redis & Background Jobs Configuration
# ==========================================

# The hostname for the Redis server (used for caching or BullMQ)
REDIS_HOST=localhost
# The port number for the Redis server
REDIS_PORT=6379
# Indicates if TLS should be used when connecting to Redis (usually true for managed instances like AWS ElastiCache)
REDIS_TLS=false


# ==========================================
# Business Logic & Fees
# ==========================================

# Fixed or percentage fee charged by the platform
PLATFORM_FEES=
# Fixed or percentage fee allocated to the kitchen
KITCHEN_FEES=
# Fixed or percentage fee allocated for the delivery
DELIVERY_FEES=